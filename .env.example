# Copie ce fichier en .env.development / .env.staging / .env.production
# Ne jamais commiter de vraies cles — voir docs/adr/006-offline-first.md pour
# le detail de la strategie de separation des environnements.

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=

# RevenueCat (sandbox en dev/staging)
REVENUECAT_API_KEY_IOS=
REVENUECAT_API_KEY_ANDROID=

# OpenAI — NE JAMAIS renseigner cote client. Cette cle vit uniquement dans
# les secrets des Supabase Edge Functions (supabase secrets set OPENAI_API_KEY=...)
OPENAI_API_KEY=

# Observabilite
SENTRY_DSN=
POSTHOG_API_KEY=

# Environnement
APP_ENV=development
